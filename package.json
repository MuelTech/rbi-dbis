{
  "name": "rbi-dbis",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@prisma/client", "@prisma/engines", "prisma", "electron", "electron-winstaller"]
  },
  "scripts": {
    "dev:server": "pnpm --filter @rbi/server dev",
    "dev:desktop": "pnpm --filter @rbi/desktop dev",
    "build:db": "pnpm --filter @rbi/db build",
    "build:server": "pnpm --filter @rbi/server build",
    "build:desktop": "pnpm --filter @rbi/desktop build",
    "db:migrate": "pnpm --filter @rbi/db exec prisma migrate dev",
    "db:generate": "pnpm --filter @rbi/db exec prisma generate",
    "db:studio": "pnpm --filter @rbi/db exec prisma studio"
  }
}
