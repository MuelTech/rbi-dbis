{
  "info": {
    "name": "RBI-DBIS Auth Flow",
    "_postman_id": "rbi-dbis-auth-flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Authentication flow tests for the RBI-DBIS Barangay Management API.\n\nRun after seeding the database (`pnpm db:seed`) so the QA account exists."
  },
  "variable": [],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Body has status ok', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Login - Success",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{qaUsername}}\",\n  \"password\": \"{{qaPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has token and user', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('token');",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  pm.expect(json).to.have.property('user');",
              "  pm.expect(json.user).to.have.property('id');",
              "  pm.expect(json.user).to.have.property('username');",
              "  pm.expect(json.user).to.have.property('roleType');",
              "  pm.expect(json.user).to.have.property('firstName');",
              "  pm.expect(json.user).to.have.property('lastName');",
              "});",
              "",
              "pm.test('Save token for subsequent requests', function () {",
              "  var json = pm.response.json();",
              "  pm.environment.set('authToken', json.token);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Login - Failure (wrong password)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{qaUsername}}\",\n  \"password\": \"wrong-password\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Body has error message', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('error');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Me - Without Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Body has error message', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('error');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Me - With Token",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has user fields', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('username');",
              "  pm.expect(json).to.have.property('roleType');",
              "  pm.expect(json).to.have.property('isActive', true);",
              "  pm.expect(json).to.have.property('firstName');",
              "  pm.expect(json).to.have.property('lastName');",
              "});"
            ]
          }
        }
      ],
      "response": []
    }
  ]
}
